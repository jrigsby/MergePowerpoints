<UserControl x:Class="PDFTools.PdfToPowerPointControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PDFTools"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- PDF File Selection -->
        <TextBlock Text="PDF File:" VerticalAlignment="Center" Margin="5" />
        <TextBox x:Name="PdfFilePathTextBox" Grid.Column="1" Margin="5" VerticalAlignment="Center" />
        <Button Content="Browse..." Grid.Column="2" Margin="5" Padding="10,2" Click="BrowseFile_Click" />

        <!-- Output Folder Selection -->
        <TextBlock Text="Output Folder:" Grid.Row="1" VerticalAlignment="Center" Margin="5" />
        <TextBox x:Name="OutputFolderTextBox" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center" />
        <Button Content="Browse..." Grid.Row="1" Grid.Column="2" Margin="5" Padding="10,2" Click="BrowseFolder_Click" />

        <!-- Output Filename Format -->
        <TextBlock Text="Filename:" Grid.Row="2" VerticalAlignment="Center" Margin="5" />
        <TextBox x:Name="FilenameTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" VerticalAlignment="Center" Text="" />

        <!-- Layout Selection -->
        <TextBlock Text="Layout:" Grid.Row="3" VerticalAlignment="Center" Margin="5" />
        <ComboBox x:Name="LayoutComboBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="Portrait" />
            <ComboBoxItem Content="Landscape" />
            <ComboBoxItem Content="Square" />
        </ComboBox>
        
        <!-- Split Button -->
        <Button Content="Convert PDF to PowerPoint" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Right" Margin="5" Padding="20,5" Click="ConvertPdfToPowerPoint_Click" />

        <!-- Results Grid -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="5" Grid.ColumnSpan="3" Margin="5" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Action" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Open" Click="OpenFile_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
